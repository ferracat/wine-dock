# Sample app: Windows Notepad (safe generic demo — no third-party vendor)
# Quick try: make demo && make install-cmd APP=example && example

APP_NAME=example
APP_DISPLAY_NAME=Notepad (Wine)

APP_IMAGE=wine-app-example
APP_EXE='C:\windows\system32\notepad.exe'

# Prefix comes from wine-base inside wine-app-example (no host wine-prefix/)
WINE_DATA_DIR=@image

WINE_GUI=1
RUN_MODE=run
USER_NAME=wine
